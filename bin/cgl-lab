#!/usr/bin/env bash
# cgl-lab <slug> — launch the Lab TUI for a specific lab
set -euo pipefail
HARNESS="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$HARNESS/bin/_studio_env.sh"
VENV="$HARNESS/studio/.venv"
if [[ $# -lt 1 ]]; then
  echo "usage: cgl-lab <slug>" >&2
  exit 2
fi
if [[ ! -x "$VENV/bin/python" ]]; then
  echo "error: textual venv missing at $VENV" >&2
  exit 1
fi
exec "$VENV/bin/python" "$HARNESS/studio/lab_tui/app.py" "$@"
